// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  phone     String?
  role      Role      @default(CLIENT)
  vehicles  Vehicle[]
  policies  Policy[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  ADMIN
  SUB_ADMIN
  CLIENT
}

model Vehicle {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licensePlate String   @unique
  vin          String?
  make         String?
  model        String?
  year         Int?
  policies     Policy[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Policy {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId       String
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  policyNumber    String       @unique
  insurerName     String // Назва страхової компанії (ТАС, ARX і т.д.)
  startDate       DateTime
  endDate         DateTime
  status          PolicyStatus @default(ACTIVE)
  mtibuStatusInfo Json? // Сирі дані з МТСБУ (опціонально для кешування)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

model News {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsultationRequest {
  id        String        @id @default(uuid())
  name      String
  email     String?
  phone     String
  service   String?
  message   String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum RequestStatus {
  PENDING
  CONTACTED
  COMPLETED
  CANCELLED
}

model PageContent {
  id        String   @id @default(uuid())
  pageKey   String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  author    String
  text      String
  rating    Int      @default(5)
  avatarUrl String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String?
  basePrice   Float
  icon        String? // Напр. назва іконки Lucide або лінк на картинку
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
